<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.LoginController" prefWidth="400" prefHeight="250">
    <children>
        <Label layoutX="30" layoutY="30" text="Login" />
        <TextField fx:id="loginField" layoutX="120" layoutY="30" prefWidth="240" />
        <Label layoutX="30" layoutY="80" text="Mot de passe" />
        <PasswordField fx:id="passwordField" layoutX="120" layoutY="80" prefWidth="240" />
        <Button fx:id="loginButton" layoutX="120" layoutY="130" text="Se connecter" onAction="#handleLogin" />
        <Label fx:id="errorLabel" layoutX="120" layoutY="180" textFill="red" />
    </children>
</AnchorPane>
